# Copy this to `.env` and fill in real values before running locally.

# MongoDB connection string (replace with your connection)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/pcsensei

# Frontend client URL (used for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=5000

# JWT secret for signing tokens
JWT_SECRET=change_this_to_a_secure_random_string

# Gemini API key (used by AI Build feature)
GEMINI_API_KEY=change_this_to_your_gemini_api_key

# Node environment
NODE_ENV=development
